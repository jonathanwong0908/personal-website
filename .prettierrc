{
  "plugins": [
    "prettier-plugin-tailwindcss",
    "@ianvs/prettier-plugin-sort-imports"
  ],
  "tailwindFunctions": ["cn", "cva"],
  "importOrder": [
    "^(react/(.*)$)|^(react$)|^(react-native(.*)$)",
    "^(next/(.*)$)|^(next$)",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/utils/(.*)$",
    "^@/components/(.*)$",
    "^@/(.*)$",
    "^[./]"
  ],
  "importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
  "importOrderTypeScriptVersion": "4.4.0",
  "overrides": [
    {
      "files": "*.json.hbs",
      "options": {
        "parser": "json",
        "formatter": "prettier-plugin-packagejson"
      }
    },
    {
      "files": "*.js.hbs",
      "options": {
        "parser": "babel",
        "formatter": "prettier-plugin-jsdoc-ast"
      }
    }
  ]
}
